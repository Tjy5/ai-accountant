# Backend runtime
SERVER_PORT=3002

# Default local development uses H2. Override these for another JDBC database.
DATABASE_URL=jdbc:h2:file:./data/ai-accountant;MODE=MySQL;DATABASE_TO_LOWER=TRUE;AUTO_SERVER=TRUE
DATABASE_USER=sa
DATABASE_PASSWORD=

# Required for production. Use a long random value and keep it secret.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=30d

# Comma-separated frontend origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI provider configuration. Base URL should be OpenAI Chat Completions compatible.
AI_ENABLED=true
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_JSON_MODE=auto
AI_BASE_URL_ALLOWLIST=
AI_ENCRYPTION_KEY=
AI_REQUEST_TIMEOUT_SECONDS=25
AI_MAX_OUTPUT_TOKENS=1200
AI_TEMPERATURE=0

# Optional MySQL profile values.
MYSQL_URL=jdbc:mysql://localhost:3306/ai_accountant?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USER=ai_accountant
MYSQL_PASSWORD=change-me
